# URL base de la API (rulo-api). Sin barra final.
# Local: copia a .env.local. Deploy: definela en Environment Variables de la plataforma.
RULO_API_URL=https://rulo-api.rulofitness-ai.workers.dev
RULO_API_KEY=

# App URL (para callbacks de MercadoPago — se envía a rulo-api en /subscriptions/checkout)
MERCADOPAGO_CALLBACK_URL=https://dashboard-rulo-fitness.vercel.app
